{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "default",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "app/globals.css",
    "baseColor": "slate",
    "cssVariables": true
  },
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils"
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "description": "Official Playwright MCP server by Microsoft. Gives the agent hands to control a real browser: navigate pages, click elements, fill forms, take screenshots, and read console output.",
      "capabilities": [
        "browser_navigate",
        "browser_click",
        "browser_type",
        "browser_screenshot",
        "browser_console_messages",
        "browser_wait_for",
        "browser_evaluate"
      ],
      "env": {
        "BROWSER": "chromium",
        "HEADLESS": "false"
      }
    }
  }
}