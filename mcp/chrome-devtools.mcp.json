{
  "version": "1.0",
  "description": "MCP configuration for Chrome DevTools",
  "capabilities": {
    "debugging": {
      "enabled": true,
      "features": [
        "element-inspector",
        "console-logging",
        "network-monitoring",
        "performance-analysis"
      ]
    },
    "navigation": {
      "enabled": true,
      "features": [
        "page-navigation",
        "screenshot-capture",
        "console-output"
      ]
    },
    "testing": {
      "enabled": true,
      "features": [
        "test-execution",
        "test-verification",
        "error-reporting"
      ]
    }
  },
  "integration": {
    "nextjs": {
      "enabled": true,
      "features": [
        "hot-reloading",
        "server-side-rendering",
        "static-site-generation"
      ]
    },
    "playwright": {
      "enabled": true,
      "features": [
        "browser-automation",
        "test-scripting",
        "headless-testing"
      ]
    }
  },
  "mcpServers": {
    "puppeteer": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "description": "Puppeteer MCP server for Chrome DevTools Protocol access. Gives the agent eyes to inspect the live DOM, read console errors, monitor network requests, and capture screenshots for visual verification.",
      "capabilities": [
        "puppeteer_navigate",
        "puppeteer_screenshot",
        "puppeteer_click",
        "puppeteer_evaluate",
        "puppeteer_fill",
        "puppeteer_select",
        "puppeteer_hover"
      ],
      "env": {
        "PUPPETEER_HEADLESS": "false"
      }
    }
  }
}